meta {
  name: daily-report/detail Copy
  type: http
  seq: 3
}

get {
  url: {{url}}/daily-report/detail?id=4
  body: formUrlEncoded
  auth: inherit
}

params:query {
  id: 4
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
