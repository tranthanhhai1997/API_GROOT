meta {
  name: /daily-report/main
  type: http
  seq: 1
}

get {
  url: {{url-v2}}/daily-report/main?year=2026&month=02
  body: formUrlEncoded
  auth: inherit
}

params:query {
  year: 2026
  month: 02
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
