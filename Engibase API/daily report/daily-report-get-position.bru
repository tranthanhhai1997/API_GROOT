meta {
  name: daily-report/get-position
  type: http
  seq: 4
}

get {
  url: {{url}}/daily-report/get-position
  body: formUrlEncoded
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
