meta {
  name: help/faqList
  type: http
  seq: 5
}

get {
  url: {{url-v2}}/help/faq-list?source_redirect=daily_report
  body: none
  auth: inherit
}

params:query {
  source_redirect: daily_report
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
