meta {
  name: help/manualList
  type: http
  seq: 3
}

get {
  url: {{url-v2}}/help/manual-list?limit=10&page=1&help_redirect=daily_report
  body: none
  auth: inherit
}

params:query {
  limit: 10
  page: 1
  help_redirect: daily_report
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
