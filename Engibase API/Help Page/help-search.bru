meta {
  name: help/search
  type: http
  seq: 8
}

get {
  url: {{url-v2}}/help/search?type=faq&limit=50&keyword=ログイン
  body: none
  auth: inherit
}

params:query {
  type: faq
  limit: 50
  keyword: ログイン
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
