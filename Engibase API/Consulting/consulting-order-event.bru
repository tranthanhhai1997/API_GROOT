meta {
  name: /consulting/order-event
  type: http
  seq: 1
}

post {
  url: {{url}}/consulting/order-event
  body: formUrlEncoded
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

body:form-urlencoded {
  cc_id: 1
  start_time: 2024/10/12 09:00
  end_time: 2024/10/14 10:00
  cate_id: 1
}

settings {
  encodeUrl: true
}
