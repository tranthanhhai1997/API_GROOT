meta {
  name: get-holiday-history
  type: http
  seq: 2
}

get {
  url: {{url-v2}}/user/get-holiday-history?month=2026/02
  body: none
  auth: inherit
}

params:query {
  month: 2026/02
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
