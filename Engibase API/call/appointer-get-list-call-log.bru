meta {
  name: appointer/get-list-call-log
  type: http
  seq: 4
}

get {
  url: {{url-v2}}/appointer/get-list-call-log?page=1&limit=30
  body: none
  auth: inherit
}

params:query {
  page: 1
  limit: 30
  ~debug_db: 1
  ~page: 1
  ~limit: 30
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
