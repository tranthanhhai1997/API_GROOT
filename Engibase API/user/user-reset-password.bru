meta {
  name: user/reset-password
  type: http
  seq: 4
}

post {
  url: {{url}}/user/reset-password
  body: formUrlEncoded
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{Jil-Token}}
}

body:form-urlencoded {
  email: nesv005@gmail.com
}

settings {
  encodeUrl: true
}
