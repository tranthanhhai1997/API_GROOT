meta {
  name: examination/list-cate
  type: http
  seq: 2
}

get {
  url: {{url-v2}}/examination/list-cate?limit=20
  body: none
  auth: inherit
}

params:query {
  limit: 20
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Content-Type: {{Content-Type}}
  version: {{version-v2}}
  App-Version: {{App-Version}}
  device-id: {{device-id}}
  Jil-Token: {{token}}
}

settings {
  encodeUrl: true
}
