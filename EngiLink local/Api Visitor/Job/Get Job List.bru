meta {
  name: Get Job List
  type: http
  seq: 1
}

get {
  url: {{url-visitor}}/jobs/list?job_openings_published=1
  body: none
  auth: inherit
}

params:query {
  job_openings_published: 1
  ~title: test_1
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token-Visitor}}
  version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
}
