meta {
  name: Create agency group
  type: http
  seq: 3
}

post {
  url: {{url-visitor}}/agency-group/create
  body: multipartForm
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token-Visitor: {{Jil_Token-Visitor}}
}

body:multipart-form {
  group_name: Test
  order: 
  note: 
  agency_id: [1,2,3]
}

settings {
  encodeUrl: true
  timeout: 0
}
