meta {
  name: Get agency group list
  type: http
  seq: 1
}

get {
  url: {{url-visitor}}/agency-group/list
  body: none
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token-Visitor: {{Jil_Token-Visitor}}
  ~version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
}
