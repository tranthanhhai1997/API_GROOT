meta {
  name: Get agency
  type: http
  seq: 2
}

get {
  url: {{url-visitor}}/agency-group/get-agency-data
  body: none
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token-Visitor: {{Jil_Token-Visitor}}
  ~version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
}
