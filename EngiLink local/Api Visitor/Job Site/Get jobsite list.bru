meta {
  name: Get jobsite list
  type: http
  seq: 1
}

get {
  url: {{url-visitor}}/jobsite/list
  body: none
  auth: inherit
}

params:query {
  ~name: マイナビ転職
  ~account: account@mynavi.jp
  ~status: 1
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
