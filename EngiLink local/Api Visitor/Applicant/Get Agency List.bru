meta {
  name: Get Agency List
  type: http
  seq: 12
}

get {
  url: {{url-visitor}}/applicants/agency-list
  body: multipartForm
  auth: inherit
}

params:query {
  ~display_name: 1
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token-Visitor}}
  version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
}
