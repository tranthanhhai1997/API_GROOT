meta {
  name: Download Interview Info Pdf
  type: http
  seq: 6
}

get {
  url: {{url-visitor}}/applicants/download-interview-info-pdf?id=1
  body: multipartForm
  auth: inherit
}

params:query {
  id: 1
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
