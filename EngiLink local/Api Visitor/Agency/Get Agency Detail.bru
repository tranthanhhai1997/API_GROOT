meta {
  name: Get Agency Detail
  type: http
  seq: 3
}

get {
  url: {{url-visitor}}/agency/detail?id=3
  body: multipartForm
  auth: inherit
}

params:query {
  id: 3
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
  followRedirects: true
  maxRedirects: 5
}
