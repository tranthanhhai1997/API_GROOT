meta {
  name: Get filter total applicant list
  type: http
  seq: 2
}

get {
  url: {{url-visitor}}/agency/filter-total-list?code=123
  body: multipartForm
  auth: inherit
}

params:query {
  code: 123
  ~id: 1
  ~corporateName: 
