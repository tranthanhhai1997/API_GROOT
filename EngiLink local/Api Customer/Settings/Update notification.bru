meta {
  name: Update notification
  type: http
  seq: 2
}

post {
  url: {{url}}/settings/notification
  body: multipartForm
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil-Token: {{token}}
}

body:multipart-form {
  mail_apply: 1
  desktop_apply: 1
  mail_message: 1
  desktop_message: 1
  mail_unreply_alert: 1
  desktop_unreply_alert: 1
  mail_interview_reminder: 0
  desktop_interview_reminder: 1
  mail_job_expire_notice: 1
  desktop_job_expire_notice: 1
}

settings {
  encodeUrl: true
}
