meta {
  name: Create pulldown items
  type: http
  seq: 6
}

post {
  url: {{url-manager}}/pulldown/items/create
  body: multipartForm
  auth: inherit
}
headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}
body:multipart-form {
  category_id: 1
  name: test
  status: 1
}

settings {
  encodeUrl: true
}
