meta {
  name: Get pulldown items by slug
  type: http
  seq: 11
}

get {
  url: {{url-manager}}/pulldown/items?slug=Transfer Count&limit=5&name=0
  body: multipartForm
  auth: inherit
}

params:query {
  slug: Transfer Count
  limit: 5
  name: 0
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}
body:multipart-form {
  category_slug: Transfer Count
}

settings {
  encodeUrl: true
}
