meta {
  name: Clear cache pulldown items
  type: http
  seq: 10
}

get {
  url: {{url-manager}}/pulldown/clear-cache
  body: multipartForm
  auth: inherit
}
headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}
body:multipart-form {
  id: 1
  order: 5
}

settings {
  encodeUrl: true
}
