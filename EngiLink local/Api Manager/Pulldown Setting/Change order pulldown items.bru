meta {
  name: Change order pulldown items
  type: http
  seq: 9
}

post {
  url: {{url-manager}}/pulldown/items/sort-order
  body: multipartForm
  auth: inherit
}
headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
  version: {{version}}
}
body:multipart-form {
  id: 1
  order: 5
}

settings {
  encodeUrl: true
}
