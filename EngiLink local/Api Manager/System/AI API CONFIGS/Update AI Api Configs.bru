  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

body:json {
  {
      "id": "5",
      "type": "PUSH_NOTIFY",
      "key": "sdaasdasd",
      "configs": "",
      "ver": "",
      "status": "1",
      "test": "1"
  }
}

settings {
  encodeUrl: true
}
