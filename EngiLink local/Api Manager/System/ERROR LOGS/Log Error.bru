meta {
  name: Log Error
  type: http
  seq: 1
}

get {
  url: {{url}}/system/log-error
  body: json
  auth: inherit
}

params:query {
  ~limit: 30
  ~page: 1
  ~method: POST
  ~from_date: 2025/10/06
  ~to_date: 2025/10/08
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil-Token: {{Jil_Token}}
}

settings {
  encodeUrl: true
}
