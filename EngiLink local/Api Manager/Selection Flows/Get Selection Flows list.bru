meta {
  name: Get Selection Flows list
  type: http
  seq: 1
}

get {
  url: {{url-manager}}/selection-flows/list
  body: none
  auth: inherit
}

params:query {
  ~is_shown: 0
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
