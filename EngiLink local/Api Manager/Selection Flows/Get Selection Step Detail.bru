meta {
  name: Get Selection Step Detail
  type: http
  seq: 3
}

get {
  url: {{url-manager}}/selection-flows/detail?id=1
  body: none
  auth: inherit
}

params:query {
  id: 1
  ~is_shown: 1
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

settings {
  encodeUrl: true
  timeout: 0
}
