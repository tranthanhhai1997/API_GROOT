meta {
  name: Edit admin user
  type: http
  seq: 4
}

post {
  url: {{url}}/admin-user/edit
  body: multipartForm
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

body:multipart-form {
  file: @file()
  id: 1
  name: test
  katakanaName: テスト
  phoneNumber: 0901234586
  email: test1@gmail.com
  groupCode: STAFF
  status: 1
}

settings {
  encodeUrl: true
}
