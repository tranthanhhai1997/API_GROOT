meta {
  name: Change order pulldown categories
  type: http
  seq: 3
}

post {
  url: {{url}}/pulldown/categories/sort-order
  body: multipartForm
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

body:multipart-form {
  id: 11
  order: 11
}

settings {
  encodeUrl: true
  timeout: 0
}
