meta {
  name: Edit Roles
  type: http
  seq: 2
}

put {
  url: {{url-agency}}/role/edit
  body: json
  auth: inherit
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token}}
}

body:json {
  {
      "id": "5",
      "remark": "test role",
      "permissions": [89,95,96,97] // mảng id của menu
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
