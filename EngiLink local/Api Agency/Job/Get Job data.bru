meta {
  name: Get Job data
  type: http
  seq: 5
}

get {
  url: {{url-agency}}/jobs/get-job-by-id?ids[]=20&ids[]=35
  body: none
  auth: inherit
}

params:query {
  ids[]: 20
  ids[]: 35
}

headers {
  Jil-Public-Key: {{Jil-Public-Key}}
  Jil_Token: {{Jil_Token-Agency}}
  version: {{version}}
}

settings {
  encodeUrl: true
  timeout: 0
}
